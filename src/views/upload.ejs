<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Italiana&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/styles.css"/>
  <style>
    body {
      font-family: 'Montserrat', sans-serif;
      background-color: #ffffff;
      color: #121212;
      letter-spacing: 0.5px;
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 2rem;
    }

    .upload-card {
      padding: 3rem;
      border-radius: 4px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
      background-color: #fff;
    }

    .upload-card h1 {
      font-family: 'Italiana', serif;
      font-size: 2.2rem;
      text-align: center;
      margin-bottom: 1rem;
      letter-spacing: 2px;
    }

    .upload-card label {
      font-weight: 500;
      margin-bottom: 0.5rem;
      display: block;
    }

    .form-group input[type="text"],
    .form-group input[type="file"] {
      border: none;
      border-bottom: 1px solid #ddd;
      border-radius: 0;
      padding: 12px 0;
      font-weight: 300;
    }

    .form-group input:focus {
      box-shadow: none;
      border-color: #121212;
    }

    #submitButton {
      background-color: #121212;
      border: none;
      letter-spacing: 2px;
      padding: 12px 25px;
      text-transform: uppercase;
      font-size: 0.8rem;
      transition: all 0.3s ease;
      width: 100%;
      margin-top: 1rem;
    }

    #submitButton:hover {
      background-color: #333;
    }

    .upload-footer {
      position: fixed;
      bottom: 20px;
      width: 100%;
      text-align: center;
      color: #989898;
      font-size: 0.8rem;
    }
  </style>
</head>
<body>
  <div class="upload-card">
    <h1><%= pageTitle %></h1>

    <form id="uploadForm">
      <div class="form-group mb-3">
        <label for="username">Username</label>
        <input id="username" type="text" class="form-control" required />
      </div>

      <div class="form-group mb-3">
        <label for="eventId">Event ID</label>
        <input id="eventId" type="text" class="form-control" required />
      </div>

      <div class="form-group mb-3">
        <label for="fileInput">Choose File</label>
        <input type="file" id="fileInput" class="form-control" />
      </div>

      <div id="progressContainer" style="display: none;">
        <div class="progress-bar mb-1">
          <div id="progressBarFill" class="fill"></div>
        </div>
        <div id="progressPercentage" class="progress-text">0%</div>
      </div>

      <p id="statusMessage" class=""></p>

      <div id="uploadSuccess" class="upload-success" style="display: none;">
        <h3>File Uploaded Successfully!</h3>
        <div class="file-details">
          <p><strong>File:</strong> <span id="fileName"></span></p>
          <p><strong>Size:</strong> <span id="fileSize"></span></p>
          <p><strong>Type:</strong> <span id="fileType"></span></p>
          <p><strong>Uploaded to:</strong> <span id="uploadPath"></span></p>
        </div>
      </div>

      <button type="submit" id="submitButton">Upload File</button>
    </form>
  </div>

  <div class="upload-footer">
    © 2025 NIEBIESKIE APARATY. All Rights Reserved.
  </div>

  <script src="/js/script.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NIEBIESKIE APARATY | User Details</title>
  <link rel="icon" href="/favicon.ico" type="image/x-icon" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Italiana&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary-color: #ffffff;
      --secondary-color: #121212;
      --accent-color: #f5f5f5;
      --text-light: #989898;
    }
    
    body {
      font-family: 'Montserrat', sans-serif;
      background-color: var(--primary-color);
      color: var(--secondary-color);
      letter-spacing: 0.5px;
      min-height: 100vh;
      padding-bottom: 60px;
    }

    .navbar {
      background-color: var(--secondary-color);
      padding: 1rem 2rem;
    }

    .navbar-brand {
      font-family: 'Italiana', serif;
      color: var(--primary-color) !important;
      font-size: 1.5rem;
      letter-spacing: 2px;
    }

    .nav-link {
      color: var(--primary-color) !important;
      letter-spacing: 1px;
      margin: 0 1rem;
      transition: opacity 0.3s ease;
    }

    .nav-link:hover {
      opacity: 0.8;
    }

    .content-container {
      max-width: 800px;
      margin: 2rem auto;
      padding: 2rem;
      background-color: var(--primary-color);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
      border-radius: 4px;
    }

    .page-title {
      font-family: 'Italiana', serif;
      font-size: 2.5rem;
      letter-spacing: 2px;
      text-align: center;
      margin-bottom: 2rem;
      position: relative;
    }

    .page-title::after {
      content: '';
      position: absolute;
      width: 50px;
      height: 1px;
      background-color: var(--secondary-color);
      bottom: -15px;
      left: 50%;
      transform: translateX(-50%);
    }

    .user-details {
      background-color: var(--accent-color);
      padding: 2rem;
      border-radius: 4px;
      margin-bottom: 2rem;
    }

    .detail-row {
      display: flex;
      margin-bottom: 1.5rem;
      align-items: center;
    }

    .detail-label {
      width: 150px;
      font-weight: 600;
      text-transform: uppercase;
      font-size: 0.8rem;
      letter-spacing: 1px;
    }

    .detail-value {
      flex: 1;
      font-size: 0.9rem;
    }

    .events-section {
      margin-top: 3rem;
    }

    .events-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
    }

    .events-title {
      font-family: 'Italiana', serif;
      font-size: 1.8rem;
      letter-spacing: 2px;
      margin: 0;
    }

    .btn-dark {
      background-color: var(--secondary-color);
      border: none;
      letter-spacing: 2px;
      padding: 12px 25px;
      text-transform: uppercase;
      font-size: 0.8rem;
      transition: all 0.3s ease;
    }

    .btn-dark:hover {
      background-color: #333;
    }

    .event-card {
      background-color: var(--accent-color);
      padding: 1.5rem;
      border-radius: 4px;
      margin-bottom: 1rem;
    }

    .event-title {
      font-size: 1.2rem;
      font-weight: 600;
      margin-bottom: 1rem;
    }

    .event-info {
      font-size: 0.9rem;
      color: var(--text-light);
      margin-bottom: 1rem;
    }

    .footer {
      position: fixed;
      bottom: 20px;
      width: 100%;
      text-align: center;
      color: var(--text-light);
      font-size: 0.8rem;
    }

    .badge {
      font-size: 0.7rem;
      padding: 0.5em 1em;
      letter-spacing: 1px;
    }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg">
    <div class="container-fluid">
      <a class="navbar-brand" href="/api-docs">NIEBIESKIE APARATY</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link active" href="/users">Users</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="content-container">
    <h1 class="page-title">User Details</h1>

    <div class="user-details">
      <div class="detail-row">
        <div class="detail-label">Username</div>
        <div class="detail-value"><%= user.username %></div>
      </div>

      <div class="detail-row">
        <div class="detail-label">Full Name</div>
        <div class="detail-value"><%= user.fullName %></div>
      </div>

      <div class="detail-row">
        <div class="detail-label">Email</div>
        <div class="detail-value"><%= user.email || 'Not provided' %></div>
      </div>

      <div class="detail-row">
        <div class="detail-label">Role</div>
        <div class="detail-value">
          <span class="badge <%= user.role === 'ADMIN' ? 'bg-danger' : 'bg-success' %>">
            <%= user.role %>
          </span>
        </div>
      </div>

      <div class="detail-row">
        <div class="detail-label">Status</div>
        <div class="detail-value">
          <span class="badge <%= user.active ? 'bg-success' : 'bg-danger' %>">
            <%= user.active ? 'Active' : 'Inactive' %>
          </span>
        </div>
      </div>

      <div class="detail-row">
        <div class="detail-label">Created At</div>
        <div class="detail-value"><%= new Date(user.createdAt).toLocaleString() %></div>
      </div>
    </div>

    <div class="events-section">
      <div class="events-header">
        <h2 class="events-title">Events</h2>
        <a href="/users/<%= user.username %>/events/create" class="btn btn-dark">Create Event</a>
      </div>

      <% if (events && events.length > 0) { %>
        <% events.forEach(event => { %>
          <div class="event-card">
            <h3 class="event-title"><%= event.title %></h3>
            <div class="event-info">
              <p><strong>Date:</strong> <%= new Date(event.date).toLocaleDateString() %></p>
              <p><strong>Description:</strong> <%= event.description || 'No description provided' %></p>
              <p><strong>Created:</strong> <%= new Date(event.createdAt).toLocaleString() %></p>
            </div>
            <a href="/events/<%= event.eventId %>" class="btn btn-dark btn-sm">View Details</a>
          </div>
        <% }); %>
      <% } else { %>
        <p class="text-center text-muted">No events found for this user.</p>
      <% } %>
    </div>

    <div class="d-flex justify-content-center mt-4">
      <a href="/users" class="btn btn-dark">Back to Users List</a>
    </div>
  </div>

  <div class="footer">
    © 2025 NIEBIESKIE APARATY. All Rights Reserved.
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
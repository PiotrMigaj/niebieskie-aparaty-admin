<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NIEBIESKIE APARATY | Users List</title>
  <link rel="icon" href="/favicon.ico" type="image/x-icon" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Italiana&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary-color: #ffffff;
      --secondary-color: #121212;
      --accent-color: #f5f5f5;
      --text-light: #989898;
    }
    
    body {
      font-family: 'Montserrat', sans-serif;
      background-color: var(--primary-color);
      color: var(--secondary-color);
      letter-spacing: 0.5px;
      min-height: 100vh;
      padding-bottom: 60px;
    }

    .navbar {
      background-color: var(--secondary-color);
      padding: 1rem 2rem;
    }

    .navbar-brand {
      font-family: 'Italiana', serif;
      color: var(--primary-color) !important;
      font-size: 1.5rem;
      letter-spacing: 2px;
    }

    .nav-link {
      color: var(--primary-color) !important;
      letter-spacing: 1px;
      margin: 0 1rem;
      transition: opacity 0.3s ease;
    }

    .nav-link:hover {
      opacity: 0.8;
    }

    .content-container {
      max-width: 1200px;
      margin: 2rem auto;
      padding: 2rem;
      background-color: var(--primary-color);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
      border-radius: 4px;
    }

    .page-title {
      font-family: 'Italiana', serif;
      font-size: 2.5rem;
      letter-spacing: 2px;
      text-align: center;
      margin-bottom: 2rem;
      position: relative;
    }

    .page-title::after {
      content: '';
      position: absolute;
      width: 50px;
      height: 1px;
      background-color: var(--secondary-color);
      bottom: -15px;
      left: 50%;
      transform: translateX(-50%);
    }

    .btn-dark {
      background-color: var(--secondary-color);
      border: none;
      letter-spacing: 2px;
      padding: 12px 25px;
      text-transform: uppercase;
      font-size: 0.8rem;
      transition: all 0.3s ease;
    }

    .btn-dark:hover {
      background-color: #333;
    }

    .btn-outline-dark {
      border: 1px solid var(--secondary-color);
      color: var(--secondary-color);
      letter-spacing: 1px;
      padding: 8px 15px;
      font-size: 0.8rem;
      transition: all 0.3s ease;
    }

    .btn-outline-dark:hover {
      background-color: var(--secondary-color);
      color: var(--primary-color);
    }

    .btn-danger {
      background-color: #dc3545;
      border: none;
      letter-spacing: 1px;
      padding: 8px 15px;
      font-size: 0.8rem;
      transition: all 0.3s ease;
    }

    .table {
      margin-top: 2rem;
    }

    .table th {
      font-weight: 600;
      text-transform: uppercase;
      font-size: 0.8rem;
      letter-spacing: 1px;
    }

    .badge {
      font-size: 0.7rem;
      padding: 0.5em 1em;
      letter-spacing: 1px;
    }

    .footer {
      position: fixed;
      bottom: 20px;
      width: 100%;
      text-align: center;
      color: var(--text-light);
      font-size: 0.8rem;
    }

    .table-responsive {
      margin-top: 2rem;
    }

    .table td {
      vertical-align: middle;
    }

    .action-buttons {
      display: flex;
      gap: 0.5rem;
    }

    .modal-content {
      border-radius: 4px;
    }

    .modal-header {
      border-bottom: none;
      padding: 2rem 2rem 1rem;
    }

    .modal-body {
      padding: 1rem 2rem;
    }

    .modal-footer {
      border-top: none;
      padding: 1rem 2rem 2rem;
    }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg">
    <div class="container-fluid">
      <a class="navbar-brand" href="/api-docs">NIEBIESKIE APARATY</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link active" href="/users">Users</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="content-container">
    <h1 class="page-title">Users List</h1>
    
    <div class="d-flex justify-content-end mb-4">
      <a href="/users/create" class="btn btn-dark">Create New User</a>
    </div>

    <div class="table-responsive">
      <table class="table">
        <thead>
          <tr>
            <th>Username</th>
            <th>Full Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Status</th>
            <th>Created At</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (users && users.length > 0) { %>
            <% users.forEach(user => { %>
              <tr>
                <td><%= user.username %></td>
                <td><%= user.fullName %></td>
                <td><%= user.email || '-' %></td>
                <td>
                  <span class="badge <%= user.role === 'ADMIN' ? 'bg-danger' : 'bg-success' %>">
                    <%= user.role %>
                  </span>
                </td>
                <td>
                  <span class="badge <%= user.active ? 'bg-success' : 'bg-danger' %>">
                    <%= user.active ? 'Active' : 'Inactive' %>
                  </span>
                </td>
                <td><%= new Date(user.createdAt).toLocaleDateString() %></td>
                <td>
                  <div class="action-buttons">
                    <a href="/users/<%= user.username %>" class="btn btn-outline-dark btn-sm">Details</a>
                    <button 
                      class="btn btn-danger btn-sm" 
                      data-bs-toggle="modal" 
                      data-bs-target="#deleteModal<%= user.username %>">
                      Delete
                    </button>
                  </div>

                  <!-- Delete Modal -->
                  <div class="modal fade" id="deleteModal<%= user.username %>" tabindex="-1">
                    <div class="modal-dialog">
                      <div class="modal-content">
                        <div class="modal-header">
                          <h5 class="modal-title">Confirm Delete</h5>
                          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                          Are you sure you want to delete user "<%= user.username %>"?
                        </div>
                        <div class="modal-footer">
                          <button type="button" class="btn btn-outline-dark" data-bs-dismiss="modal">Cancel</button>
                          <form action="/users/<%= user.username %>/delete" method="POST" style="display: inline;">
                            <button type="submit" class="btn btn-danger">Delete</button>
                          </form>
                        </div>
                      </div>
                    </div>
                  </div>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="7" class="text-center">No users found</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="footer">
    © 2025 NIEBIESKIE APARATY. All Rights Reserved.
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NIEBIESKIE APARATY | Admin Login</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Italiana&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary-color: #ffffff;
      --secondary-color: #121212;
      --accent-color: #f5f5f5;
      --text-light: #989898;
    }
    
    body {
      font-family: 'Montserrat', sans-serif;
      background-color: var(--primary-color);
      color: var(--secondary-color);
      letter-spacing: 0.5px;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
    }
    
    .login-container {
      width: 100%;
      max-width: 400px;
      padding: 3rem;
      background-color: var(--primary-color);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
      border-radius: 4px;
    }
    
    .login-title {
      font-family: 'Italiana', serif;
      font-size: 2.5rem;
      letter-spacing: 2px;
      text-align: center;
      margin-bottom: 2rem;
      position: relative;
    }
    
    .login-title::after {
      content: '';
      position: absolute;
      width: 50px;
      height: 1px;
      background-color: var(--secondary-color);
      bottom: -15px;
      left: 50%;
      transform: translateX(-50%);
    }
    
    .login-subtitle {
      text-align: center;
      font-weight: 300;
      color: var(--text-light);
      margin-bottom: 2rem;
    }
    
    .brand-text {
      font-family: 'Italiana', serif;
      font-size: 1.8rem;
      letter-spacing: 2px;
      text-align: center;
      margin-bottom: 2rem;
    }
    
    .form-control {
      border: none;
      border-bottom: 1px solid #ddd;
      border-radius: 0;
      padding: 15px 0;
      margin-bottom: 20px;
      font-weight: 300;
    }
    
    .form-control:focus {
      box-shadow: none;
      border-color: var(--secondary-color);
    }
    
    .btn-dark {
      background-color: var(--secondary-color);
      border: none;
      letter-spacing: 2px;
      padding: 12px 25px;
      text-transform: uppercase;
      font-size: 0.8rem;
      transition: all 0.3s ease;
      width: 100%;
      margin-top: 1rem;
    }
    
    .btn-dark:hover {
      background-color: #333;
    }
    
    .login-footer {
      position: fixed;
      bottom: 20px;
      width: 100%;
      text-align: center;
      color: var(--text-light);
      font-size: 0.8rem;
    }
  </style>
</head>
<body>
  <div class="login-container">
    <h1 class="brand-text">NIEBIESKIE APARATY</h1>
    <h2 class="login-title">Admin Access</h2>
    <p class="login-subtitle">Please enter your credentials to continue</p>
    
    <form action="/login" method="POST">
      <div class="mb-3">
        <input type="text" name="username" class="form-control" placeholder="Username" required>
      </div>
      <div class="mb-3">
        <input type="password" name="password" class="form-control" placeholder="Password" required>
      </div>
      <button type="submit" class="btn btn-dark">LOGIN</button>
    </form>
  </div>
  
  <div class="login-footer">
    © 2025 NIEBIESKIE APARATY. All Rights Reserved.
  </div>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NIEBIESKIE APARATY | Event Details</title>
  <link rel="icon" href="/favicon.ico" type="image/x-icon" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Italiana&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css"/>
  <style>
    :root {
      --primary-color: #ffffff;
      --secondary-color: #121212;
      --accent-color: #f5f5f5;
      --text-light: #989898;
    }
    
    body {
      font-family: 'Montserrat', sans-serif;
      background-color: var(--primary-color);
      color: var(--secondary-color);
      letter-spacing: 0.5px;
      min-height: 100vh;
      padding-bottom: 60px;
    }

    .navbar {
      background-color: var(--secondary-color);
      padding: 1rem 2rem;
    }

    .navbar-brand {
      font-family: 'Italiana', serif;
      color: var(--primary-color) !important;
      font-size: 1.5rem;
      letter-spacing: 2px;
    }

    .nav-link {
      color: var(--primary-color) !important;
      letter-spacing: 1px;
      margin: 0 1rem;
      transition: opacity 0.3s ease;
    }

    .nav-link:hover {
      opacity: 0.8;
    }

    .content-container {
      max-width: 800px;
      margin: 2rem auto;
      padding: 2rem;
      background-color: var(--primary-color);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
      border-radius: 4px;
    }

    .page-title {
      font-family: 'Italiana', serif;
      font-size: 2.5rem;
      letter-spacing: 2px;
      text-align: center;
      margin-bottom: 2rem;
      position: relative;
    }

    .page-title::after {
      content: '';
      position: absolute;
      width: 50px;
      height: 1px;
      background-color: var(--secondary-color);
      bottom: -15px;
      left: 50%;
      transform: translateX(-50%);
    }

    .event-details {
      background-color: var(--accent-color);
      padding: 2rem;
      border-radius: 4px;
      margin-bottom: 2rem;
    }

    .detail-row {
      display: flex;
      margin-bottom: 1.5rem;
      align-items: center;
    }

    .detail-label {
      width: 150px;
      font-weight: 600;
      text-transform: uppercase;
      font-size: 0.8rem;
      letter-spacing: 1px;
    }

    .detail-value {
      flex: 1;
      font-size: 0.9rem;
    }

    .image-upload-section {
      margin-top: 2rem;
      padding: 2rem;
      background-color: var(--accent-color);
      border-radius: 4px;
    }

    .image-preview {
      width: 100%;
      max-height: 300px;
      object-fit: cover;
      border-radius: 4px;
      margin-bottom: 1rem;
    }

    .upload-form {
      margin-top: 1rem;
    }

    .btn-dark {
      background-color: var(--secondary-color);
      border: none;
      letter-spacing: 2px;
      padding: 12px 25px;
      text-transform: uppercase;
      font-size: 0.8rem;
      transition: all 0.3s ease;
    }

    .btn-dark:hover {
      background-color: #333;
    }

    .footer {
      position: fixed;
      bottom: 20px;
      width: 100%;
      text-align: center;
      color: var(--text-light);
      font-size: 0.8rem;
    }

    #progressContainer {
      margin-top: 1rem;
      display: none;
    }

    .progress-bar {
      height: 8px;
      background-color: #e9ecef;
      border-radius: 4px;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      background-color: var(--secondary-color);
      transition: width 0.3s ease;
    }

    .status-message {
      margin-top: 0.5rem;
      font-size: 0.9rem;
    }

    .success {
      color: #198754;
    }

    .error {
      color: #dc3545;
    }

    .gallery-image {
      width: 100%;
      height: auto;
      max-height: 400px;
      object-fit: contain;
      border-radius: 8px;
      margin-bottom: 2rem;
    }

    .no-image-placeholder {
      width: 100%;
      height: 200px;
      background-color: #f8f9fa;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 8px;
      margin-bottom: 2rem;
      color: #6c757d;
      font-size: 1.1rem;
    }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg">
    <div class="container-fluid">
      <a class="navbar-brand" href="/api-docs">NIEBIESKIE APARATY</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link active" href="/users">Users</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="content-container">
    <h1 class="page-title">Event Details</h1>

    <div class="event-details">
      <div class="detail-row">
        <div class="detail-label">Title</div>
        <div class="detail-value"><%= event.title %></div>
      </div>

      <div class="detail-row">
        <div class="detail-label">Date</div>
        <div class="detail-value"><%= new Date(event.date).toLocaleDateString() %></div>
      </div>

      <div class="detail-row">
        <div class="detail-label">Description</div>
        <div class="detail-value"><%= event.description || 'No description provided' %></div>
      </div>

      <div class="detail-row">
        <div class="detail-label">Username</div>
        <div class="detail-value"><%= event.username %></div>
      </div>

      <div class="detail-row">
        <div class="detail-label">Created At</div>
        <div class="detail-value"><%= new Date(event.createdAt).toLocaleString() %></div>
      </div>
    </div>

    <div class="image-upload-section">
      <h3 class="mb-4">Event Gallery</h3>
      
      <% if (event.imagePlaceholderObjectKey && event.signedImageUrl) { %>
        <img 
          src="<%= event.signedImageUrl %>" 
          alt="Event gallery image"
          class="gallery-image"
        />
      <% } else { %>
        <div class="no-image-placeholder">
          <p>No gallery image available</p>
        </div>
      <% } %>

      <form id="uploadForm" class="upload-form">
        <input type="hidden" id="eventId" value="<%= event.eventId %>" />
        <input type="hidden" id="username" value="<%= event.username %>" />
        
        <div class="mb-3">
          <label for="fileInput" class="form-label">Choose Image</label>
          <input type="file" id="fileInput" class="form-control" accept="image/*" required />
        </div>

        <div id="progressContainer">
          <div class="progress-bar">
            <div id="progressBarFill" class="progress-fill" style="width: 0%"></div>
          </div>
          <div id="progressPercentage" class="status-message">0%</div>
        </div>

        <p id="statusMessage" class="status-message"></p>

        <button type="submit" id="submitButton" class="btn btn-dark">Upload Image</button>
      </form>
    </div>

    <div class="d-flex justify-content-center mt-4">
      <a href="/users/<%= event.username %>" class="btn btn-dark">Back to User</a>
    </div>
  </div>

  <div class="footer">
    © 2025 NIEBIESKIE APARATY. All Rights Reserved.
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/details.js"></script>
</body>
</html>
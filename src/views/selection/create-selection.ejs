<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NIEBIESKIE APARATY | Create Selection</title>
  <link rel="icon" href="/favicon.ico" type="image/x-icon" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Italiana&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary-color: #ffffff;
      --secondary-color: #121212;
      --accent-color: #f5f5f5;
      --text-light: #989898;
    }
    
    body {
      font-family: 'Montserrat', sans-serif;
      background-color: var(--primary-color);
      color: var(--secondary-color);
      letter-spacing: 0.5px;
      min-height: 100vh;
      padding-bottom: 60px;
    }

    .navbar {
      background-color: var(--secondary-color);
      padding: 1rem 2rem;
    }

    .navbar-brand {
      font-family: 'Italiana', serif;
      color: var(--primary-color) !important;
      font-size: 1.5rem;
      letter-spacing: 2px;
    }

    .nav-link {
      color: var(--primary-color) !important;
      letter-spacing: 1px;
      margin: 0 1rem;
      transition: opacity 0.3s ease;
    }

    .nav-link:hover {
      opacity: 0.8;
    }

    .content-container {
      max-width: 600px;
      margin: 2rem auto;
      padding: 2rem;
      background-color: var(--primary-color);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
      border-radius: 4px;
    }

    .page-title {
      font-family: 'Italiana', serif;
      font-size: 2.5rem;
      letter-spacing: 2px;
      text-align: center;
      margin-bottom: 2rem;
      position: relative;
    }

    .page-title::after {
      content: '';
      position: absolute;
      width: 50px;
      height: 1px;
      background-color: var(--secondary-color);
      bottom: -15px;
      left: 50%;
      transform: translateX(-50%);
    }

    .form-section {
      background-color: var(--accent-color);
      padding: 2rem;
      border-radius: 4px;
      margin-bottom: 2rem;
    }

    .form-label {
      font-weight: 600;
      text-transform: uppercase;
      font-size: 0.8rem;
      letter-spacing: 1px;
      color: var(--text-light);
      margin-bottom: 0.5rem;
    }

    .form-control {
      border: 1px solid #ddd;
      border-radius: 4px;
      padding: 12px 15px;
      font-size: 0.95rem;
      transition: border-color 0.3s ease;
      background-color: var(--primary-color);
    }

    .form-control:focus {
      border-color: var(--secondary-color);
      box-shadow: 0 0 0 0.2rem rgba(18, 18, 18, 0.1);
      background-color: var(--primary-color);
    }

    .form-control:disabled {
      background-color: #f8f9fa;
      color: #6c757d;
    }

    .btn-dark {
      background-color: var(--secondary-color);
      border: none;
      letter-spacing: 2px;
      padding: 12px 25px;
      text-transform: uppercase;
      font-size: 0.8rem;
      transition: all 0.3s ease;
      border-radius: 4px;
    }

    .btn-dark:hover {
      background-color: #333;
    }

    .btn-outline-dark {
      color: var(--secondary-color);
      border-color: var(--secondary-color);
      letter-spacing: 2px;
      padding: 12px 25px;
      text-transform: uppercase;
      font-size: 0.8rem;
      transition: all 0.3s ease;
      border-radius: 4px;
    }

    .btn-outline-dark:hover {
      background-color: var(--secondary-color);
      border-color: var(--secondary-color);
      color: var(--primary-color);
    }

    .footer {
      position: fixed;
      bottom: 20px;
      width: 100%;
      text-align: center;
      color: var(--text-light);
      font-size: 0.8rem;
    }

    .form-group {
      margin-bottom: 1.5rem;
    }

    .button-group {
      display: flex;
      gap: 1rem;
      justify-content: center;
      margin-top: 2rem;
    }

    .info-box {
      background-color: #e7f3ff;
      border: 1px solid #b3d7ff;
      border-radius: 4px;
      padding: 1rem;
      margin-bottom: 2rem;
      font-size: 0.9rem;
      color: #0066cc;
    }

    .info-box i {
      margin-right: 0.5rem;
    }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg">
    <div class="container-fluid">
      <a class="navbar-brand" href="/api-docs">NIEBIESKIE APARATY</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link active" href="/users">Users</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="content-container">
    <h1 class="page-title">Create Selection</h1>

    <div class="info-box">
      <i class="fas fa-info-circle"></i>
      Create a photo selection for this event. Users will be able to select up to the specified number of photos.
    </div>

    <div class="form-section">
      <form id="createSelectionForm" method="POST" action="/selection/create-selection">
        <!-- Hidden fields for form submission -->
        <input type="hidden" name="eventId" value="<%= eventId %>" />
        <input type="hidden" name="eventTitle" value="<%= eventTitle %>" />
        <input type="hidden" name="username" value="<%= username %>" />

        <div class="form-group">
          <label for="eventId" class="form-label">Event ID</label>
          <input 
            type="text" 
            id="eventId" 
            class="form-control" 
            value="<%= eventId %>" 
            readonly 
            disabled
          />
        </div>

        <div class="form-group">
          <label for="eventTitle" class="form-label">Event Title</label>
          <input 
            type="text" 
            id="eventTitle" 
            class="form-control" 
            value="<%= eventTitle %>" 
            readonly 
            disabled
          />
        </div>

        <div class="form-group">
          <label for="username" class="form-label">Username</label>
          <input 
            type="text" 
            id="username" 
            class="form-control" 
            value="<%= username %>" 
            readonly 
            disabled
          />
        </div>

        <div class="form-group">
          <label for="maxPhotos" class="form-label">Maximum Number of Photos</label>
          <input 
            type="number" 
            id="maxPhotos" 
            name="maxPhotos" 
            class="form-control" 
            min="1" 
            max="100" 
            placeholder="Enter maximum number of photos (1-100)"
            required
          />
          <small class="form-text text-muted">
            Specify how many photos users can select from this event's gallery.
          </small>
        </div>

        <div class="button-group">
          <a href="/events/<%= eventId %>" class="btn btn-outline-dark">
            <i class="fas fa-arrow-left"></i> Back to Event
          </a>
          <button type="submit" class="btn btn-dark" id="submitBtn">
            <i class="fas fa-plus"></i> Create Selection
          </button>
        </div>
      </form>
    </div>
  </div>

  <div class="footer">
    © 2025 NIEBIESKIE APARATY. All Rights Reserved.
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('createSelectionForm');
      const maxPhotosInput = document.getElementById('maxPhotos');
      const submitBtn = document.getElementById('submitBtn');

      // Form validation
      form.addEventListener('submit', (e) => {
        const maxPhotos = parseInt(maxPhotosInput.value);
        
        if (!maxPhotos || maxPhotos < 1 || maxPhotos > 100) {
          e.preventDefault();
          alert('Please enter a valid number of photos between 1 and 100.');
          maxPhotosInput.focus();
          return;
        }

        // Disable submit button to prevent double submission
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Creating...';
      });

      // Input validation
      maxPhotosInput.addEventListener('input', (e) => {
        const value = parseInt(e.target.value);
        if (value && (value < 1 || value > 100)) {
          e.target.setCustomValidity('Number must be between 1 and 100');
        } else {
          e.target.setCustomValidity('');
        }
      });
    });
  </script>
</body>
</html>
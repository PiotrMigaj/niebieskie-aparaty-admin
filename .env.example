AWS_SECRET_ACCESS_KEY=
# DYNAMODB_ENDPOINT=http://localhost:8000  # uncomment for local DynamoDB

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
